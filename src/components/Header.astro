---
import LanguageToggle from './LanguageToggle.astro';
import type { Lang } from '../lib/i18n';
import { localizedHref } from '../lib/paths';
import { repo } from '../config';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = lang === 'zh'
  ? { name: '公平档案', submit: '提交线索', githubLabel: '在 GitHub 上查看' }
  : { name: 'Fairness Archive', submit: 'Submit', githubLabel: 'View on GitHub' };
const githubUrl = `https://github.com/${repo}`;
---
<header class="site-header">
  <a href={localizedHref(lang === 'zh' ? '/zh/' : '/')} class="wordmark">{t.name}</a>
  <div class="actions">
    <LanguageToggle current={lang} />
    <a href={githubUrl} class="btn-icon" aria-label={t.githubLabel} target="_blank" rel="noopener noreferrer">
      <svg data-component="Octicon" aria-hidden="true" focusable="false" class="octicon octicon-mark-github" viewBox="0 0 24 24" width="32" height="32" fill="currentColor" display="inline-block" overflow="visible" style="vertical-align:text-bottom">
        <path d="M10.226 17.284c-2.965-.36-5.054-2.493-5.054-5.256 0-1.123.404-2.336 1.078-3.144-.292-.741-.247-2.314.09-2.965.898-.112 2.111.36 2.83 1.01.853-.269 1.752-.404 2.853-.404 1.1 0 1.999.135 2.807.382.696-.629 1.932-1.1 2.83-.988.315.606.36 2.179.067 2.942.72.854 1.101 2 1.101 3.167 0 2.763-2.089 4.852-5.098 5.234.763.494 1.28 1.572 1.28 2.807v2.336c0 .674.561 1.056 1.235.786 4.066-1.55 7.255-5.615 7.255-10.646C23.5 6.188 18.334 1 11.978 1 5.62 1 .5 6.188.5 12.545c0 4.986 3.167 9.12 7.435 10.669.606.225 1.19-.18 1.19-.786V20.63a2.9 2.9 0 0 1-1.078.224c-1.483 0-2.359-.808-2.987-2.313-.247-.607-.517-.966-1.034-1.033-.27-.023-.359-.135-.359-.27 0-.27.45-.471.898-.471.652 0 1.213.404 1.797 1.235.45.651.921.943 1.483.943.561 0 .92-.202 1.437-.719.382-.381.674-.718.944-.943"></path>
      </svg>
    </a>
    <a href={localizedHref(lang === 'zh' ? '/zh/submit' : '/submit')} class="btn-primary">{t.submit}</a>
  </div>
</header>
<style>
.site-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--space-lg) var(--space-xl);
  max-width: 1200px; margin: 0 auto;
  border-bottom: 1px solid var(--hairline);
}
.wordmark { font-family: var(--font-display); font-size: 24px; color: var(--ink); text-decoration: none; }
.actions { display: flex; align-items: center; gap: var(--space-md); }
.btn-primary {
  background: var(--primary); color: var(--on-primary); text-decoration: none;
  padding: 12px 20px; border-radius: var(--radius-md); font-size: 14px; font-weight: 500;
  min-height: 44px; display: inline-flex; align-items: center;
}
.btn-primary:hover { background: var(--primary-active); }
.btn-icon {
  display: inline-flex; align-items: center; justify-content: center;
  min-height: 44px; min-width: 44px; padding: 0 var(--space-sm);
  border-radius: var(--radius-md); color: var(--muted);
  text-decoration: none; transition: color .15s ease, background .15s ease;
}
.btn-icon:hover { color: var(--ink); background: var(--surface-card); }
@media (max-width: 768px) {
  .site-header { padding: var(--space-md); }
  .wordmark { font-size: 20px; }
}
</style>
