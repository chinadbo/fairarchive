---
import type { Lang } from '../lib/i18n';
interface Props { status: string; lang?: Lang; }
const { status, lang = 'en' } = Astro.props;
const map: Record<string, { cls: string; zh: string; en: string }> = {
  '报道争议': { cls: 'b-reported', zh: '报道争议', en: 'Reported Dispute' },
  '已被质疑': { cls: 'b-questioned', zh: '已被质疑', en: 'Questioned' },
  '官方裁定': { cls: 'b-ruled', zh: '官方裁定', en: 'Official Ruling' },
};
const s = map[status] ?? map['报道争议'];
const label = lang === 'zh' ? s.zh : s.en;
---
<span class:list={['badge', s.cls]}>{label}</span>
<style>
.badge {
  display: inline-block; font-size: 12px; font-weight: 500; letter-spacing: 0.04em;
  padding: 4px 12px; border-radius: var(--radius-pill); line-height: 1.4;
}
.b-reported { background: var(--surface-card); color: var(--ink); }
.b-questioned { background: var(--warning); color: var(--on-signal); }
.b-ruled { background: var(--success); color: var(--on-signal); }
</style>
