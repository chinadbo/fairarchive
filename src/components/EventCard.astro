---
import StatusBadge from './StatusBadge.astro';
import { localizedTitle, localizedSummary, type Lang } from '../lib/i18n';
import { localizedHref } from '../lib/paths';
import type { EventEntry } from '../content';
interface Props { event: EventEntry; lang: Lang; }
const { event, lang } = Astro.props;
const title = localizedTitle(event, lang);
const summary = localizedSummary(event, lang);
const d = event.data.date;
const dateStr = lang === 'zh'
  ? `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`
  : d.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' });
const href = localizedHref(lang === 'zh' ? `/event/${event.id}` : `/en/event/${event.id}`);
---
<article class="card" data-event-id={event.id}>
  <div class="card-head">
    <time datetime={d.toISOString()} class="date">{dateStr}</time>
    <span class="cat">{event.data.category}</span>
    <StatusBadge status={event.data.status} />
  </div>
  <h3 class="card-title">
    <a href={href}>{title.text}</a>
    {title.fallback && <span class="fb" title="暂无英文">⌖</span>}
  </h3>
  <p class="card-summary">{summary.text}{summary.fallback ? ' ⌖' : ''}</p>
</article>
<style>
.card {
  background: var(--surface-card); border-radius: var(--radius-lg);
  padding: var(--space-xl); margin-bottom: var(--space-lg);
}
.card-head { display: flex; align-items: center; gap: var(--space-sm); flex-wrap: wrap; margin-bottom: var(--space-sm); }
.date { font-size: 13px; color: var(--muted); }
.cat { font-size: 12px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
.card-title { font-size: 22px; margin: 0 0 var(--space-xs); }
.card-title a { color: var(--ink); text-decoration: none; }
.card-title a:hover { color: var(--primary); }
.card-summary { color: var(--body); line-height: 1.55; margin: 0; }
.fb { color: var(--muted-soft); font-size: 0.8em; }
</style>
