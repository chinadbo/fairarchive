    'COVID隔离': 'COVID Quarantine',
    'X手势': 'X Gesture',
  };
  return map[tag] ?? tag;
}

const normalizedEvents: NormalizedEvent[] = events.map((event) => {
  const title = localizedTitle(event, lang);
  const summary = localizedSummary(event, lang);
  const localizedTags = event.data.tags.map((tag: string) => localizeTag(tag, lang));
  return {
    id: event.id,
    date: event.data.date.toISOString(),
    category: localizeCategory(event.data.category, lang),
    status: localizeStatus(event.data.status, lang),
    tags: localizedTags,
    title: title.text,
    summary: summary.text,
    searchText: `${title.text} ${summary.text} ${localizedTags.join(' ')}`,
  };
});
---
<filter-bar data-lang={lang}>
  <script type="application/json" set:html={JSON.stringify(normalizedEvents)} />
  <div class="filter-row">
    <select id="f-cat" class="sel" aria-label={labels.categories}><option value="">{labels.all}</option>{allCats.map((c) => <option value={localizeCategory(c, lang)}>{localizeCategory(c, lang)}</option>)}</select>
    <select id="f-status" class="sel" aria-label={labels.status}><option value="">{labels.all}</option>{allStatus.map((s) => <option value={localizeStatus(s, lang)}>{localizeStatus(s, lang)}</option>)}</select>
    <select id="f-tag" class="sel" aria-label={labels.tags}><option value="">{labels.all}</option>{allTags.map((t) => <option value={localizeTag(t, lang)}>{localizeTag(t, lang)}</option>)}</select>
    <input id="f-q" class="inp" type="search" placeholder={labels.search} />
  </div>
</filter-bar>
<script>
  import { setupFilter } from './FilterBar.client.ts';
  const root = document.querySelector('filter-bar');
  if (root) setupFilter(root as HTMLElement);
</script>
<style>
.filter-row { display: flex; gap: var(--space-sm); flex-wrap: wrap; max-width: 820px; margin: 0 auto var(--space-xl); }
.sel, .inp { background: var(--canvas); border: 1px solid var(--hairline); border-radius: var(--radius-md); padding: 12px 14px; font: inherit; color: var(--ink); min-height: 44px; }
.inp { flex: 1; min-width: 200px; }
</style>
