---
import type { EventEntry } from '../content';
import type { Lang } from '../lib/i18n';
import type { NormalizedEvent } from '../lib/filters';
import { localizedTitle, localizedSummary } from '../lib/i18n';
interface Props { events: EventEntry[]; lang: Lang; }
const { events, lang } = Astro.props;
const labels = lang === 'zh'
  ? { categories: '分类', status: '状态', search: '搜索事件…', all: '全部', tags: '标签' }
  : { categories: 'Category', status: 'Status', search: 'Search…', all: 'All', tags: 'Tags' };
const categoryLabels: Record<string, { zh: string; en: string }> = {
  '判罚争议': { zh: '判罚争议', en: 'Disputed Call' },
  '裁判执法': { zh: '裁判执法', en: 'Refereeing' },
  'FIFA治理': { zh: 'FIFA治理', en: 'FIFA Governance' },
  '种族歧视指控': { zh: '种族歧视指控', en: 'Racism Allegation' },
  '其他': { zh: '其他', en: 'Other' },
};
const statusLabels: Record<string, { zh: string; en: string }> = {
  '报道争议': { zh: '报道争议', en: 'Reported Dispute' },
  '已被质疑': { zh: '已被质疑', en: 'Questioned' },
  '官方裁定': { zh: '官方裁定', en: 'Official Ruling' },
};
const allCats = [...new Set(events.map((e) => e.data.category))];
const allStatus = ['报道争议', '已被质疑', '官方裁定'];
const allTags = [...new Set(events.flatMap((e) => e.data.tags))].slice(0, 20);

function localizeCategory(category: string, lang: Lang) {
  return categoryLabels[category]?.[lang] ?? category;
}

function localizeStatus(status: string, lang: Lang) {
  return statusLabels[status]?.[lang] ?? status;
}

