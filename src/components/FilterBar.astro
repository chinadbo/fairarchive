---
import type { EventEntry } from '../content';
import type { Lang } from '../lib/i18n';
import { toNormalized } from '../lib/filters';
interface Props { events: EventEntry[]; lang: Lang; }
const { events, lang } = Astro.props;
const labels = lang === 'zh'
  ? { categories: '分类', status: '状态', search: '搜索事件…', all: '全部', tags: '标签' }
  : { categories: 'Category', status: 'Status', search: 'Search…', all: 'All', tags: 'Tags' };
const allCats = [...new Set(events.map((e) => e.data.category))];
const allStatus = ['报道争议', '已被质疑', '官方裁定'];
const allTags = [...new Set(events.flatMap((e) => e.data.tags))].slice(0, 20);
---
<filter-bar data-lang={lang}>
  <script type="application/json" set:html={JSON.stringify(events.map(toNormalized))} />
  <div class="filter-row">
    <select id="f-cat" class="sel"><option value="">{labels.all}</option>{allCats.map((c) => <option value={c}>{c}</option>)}</select>
    <select id="f-status" class="sel"><option value="">{labels.all}</option>{allStatus.map((s) => <option value={s}>{s}</option>)}</select>
    <select id="f-tag" class="sel"><option value="">{labels.all}</option>{allTags.map((t) => <option value={t}>{t}</option>)}</select>
    <input id="f-q" class="inp" type="search" placeholder={labels.search} />
  </div>
</filter-bar>
<script>
  import { setupFilter } from './FilterBar.client.ts';
  const root = document.querySelector('filter-bar');
  if (root) setupFilter(root as HTMLElement);
</script>
<style>
.filter-row { display: flex; gap: var(--space-sm); flex-wrap: wrap; max-width: 820px; margin: 0 auto var(--space-xl); }
.sel, .inp { background: var(--canvas); border: 1px solid var(--hairline); border-radius: var(--radius-md); padding: 12px 14px; font: inherit; color: var(--ink); min-height: 44px; }
.inp { flex: 1; min-width: 200px; }
</style>
