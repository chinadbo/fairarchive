    'FIFA纪律': 'FIFA Discipline',
    'FIFA纪律处罚': 'FIFA Disciplinary Sanction',
    'FIFA禁赛': 'FIFA Suspension',
    '上诉': 'Appeal',
    '抵制': 'Boycott',
