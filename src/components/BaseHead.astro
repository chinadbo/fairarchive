---
import type { Lang } from '../lib/i18n';
interface Props { title: string; description?: string; lang?: Lang; }
const { title, lang = 'en', description = lang === 'zh' ? '足坛公平正义档案' : 'A restrained archive of disputed football incidents and governance controversies.' } = Astro.props;
import '../styles/global.css';
const faviconHref = `${import.meta.env.BASE_URL}favicon.svg`;
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={faviconHref} />
<link rel="shortcut icon" href={faviconHref} />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
