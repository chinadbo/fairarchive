---
import Base from '../../layouts/Base.astro';
import { repo } from '../../config';
---
<Base title="Submit a Lead · Fairness Archive" lang="en">
  <section style="max-width:720px;margin:0 auto;padding:48px 32px 96px;">
    <h1>Submit a Lead</h1>
    <p>Fill in the details below. Submitting will open a pre-filled GitHub Issue for review before it enters the archive. A source link is required.</p>
    <form id="submit-form">
      <label>Date <input name="date" type="date" required /></label>
      <label>Category <select name="category"><option>Disputed call</option><option>Refereeing</option><option>FIFA governance</option><option>Racism allegation</option><option>Other</option></select></label>
      <label>Status <select name="status"><option>Reported dispute</option><option>Called into question</option><option>Official ruling</option></select></label>
      <label>Title (English) <input name="title_en" required /></label>
      <label>Title (Chinese) <input name="title_zh" /></label>
      <label>Summary (English) <textarea name="summary_en" required></textarea></label>
      <label>Source URL (required) <input name="source" type="url" required placeholder="https://…" /></label>
      <button type="submit" class="btn-primary">Open Issue</button>
    </form>
  </section>
</Base>
<script is:inline define:vars={{ repo }}>
  const f = document.getElementById('submit-form');
  f.addEventListener('submit', (e) => {
    e.preventDefault();
    const d = new FormData(f);
    const title = `[Lead] ${d.get('title_en') || d.get('title_zh')}`;
    const body = [
      `Date: ${d.get('date')}`, `Category: ${d.get('category')}`, `Status: ${d.get('status')}`,
      `Title (en): ${d.get('title_en')}`, `Title (zh): ${d.get('title_zh')}`,
      `Summary (en): ${d.get('summary_en')}`, `Source: ${d.get('source')}`,
      '', '--- Please verify the source; add the accused party response and any subsequent ruling where applicable.', '',
    ].join('\n');
    window.open(`https://github.com/${repo}/issues/new?title=${encodeURIComponent(title)}&body=${encodeURIComponent(body)}`, '_blank');
  });
</script>
<style>
form { display: grid; gap: var(--space-md); }
label { display: grid; gap: var(--space-xxs); font-size: 14px; color: var(--body-strong); }
input, select, textarea { background: var(--canvas); border: 1px solid var(--hairline); border-radius: var(--radius-md); padding: 10px 14px; font: inherit; color: var(--ink); min-height: 44px; }
.btn-primary { background: var(--primary); color: var(--on-primary); border: none; padding: 10px 20px; border-radius: var(--radius-md); font-size: 14px; font-weight: 500; min-height: 44px; cursor: pointer; }
.btn-primary:hover { background: var(--primary-active); }
</style>
