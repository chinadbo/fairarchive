---
import Base from '../../layouts/Base.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import SourceList from '../../components/SourceList.astro';
import { getAllEvents } from '../../content';
import { render } from 'astro:content';
import { localizedTitle, localizedSummary } from '../../lib/i18n';

export async function getStaticPaths() {
  const events = await getAllEvents();
  return events.map((event) => ({ params: { id: event.id }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const title = localizedTitle(event, 'en');
const summary = localizedSummary(event, 'en');
const d = event.data.date;
const dateStr = d.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' });
const categoryLabels: Record<string, string> = {
  '判罚争议': 'Disputed Call',
  '裁判执法': 'Refereeing',
  'FIFA治理': 'FIFA Governance',
  '种族歧视指控': 'Racism Allegation',
  '其他': 'Other',
};
---
<Base title={`${title.text} · Fairness Archive`} lang="en" description={summary.text}>
  <article style="max-width:820px;margin:0 auto;padding:48px 32px 96px;">
    <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:16px;">
      <time datetime={d.toISOString()} class="muted">{dateStr}</time>
      <span class="cat">{categoryLabels[event.data.category] ?? event.data.category}</span>
      <StatusBadge status={event.data.status} lang="en" />
    </div>
    <h1>{title.text}</h1>
    <p style="font-size:18px;color:var(--body-strong);line-height:1.6;">{summary.text}</p>
    {event.data.note_en && <blockquote class="entry-note"><p>{event.data.note_en}</p></blockquote>}
    <Content />
    <SourceList sources={event.data.sources} lang="en" />
    {event.data.response && (
      <section class="block">
        <h2>Response</h2>
        <p>{event.data.response.text_en ?? event.data.response.text_zh}</p>
        <SourceList sources={[event.data.response.source]} lang="en" />
      </section>
    )}
    {event.data.ruling ? (
      <section class="block">
        <h2>Ruling</h2>
        <p>{event.data.ruling.verdict_en ?? event.data.ruling.verdict_zh}</p>
        <SourceList sources={[event.data.ruling.source]} lang="en" />
      </section>
    ) : (
      <p class="muted">No official ruling on record.</p>
    )}
  </article>
</Base>
<style>
.cat { font-size: 12px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
.muted { color: var(--muted); }
.block { margin-top: var(--space-lg); padding-top: var(--space-lg); border-top: 1px solid var(--hairline); }
.entry-note {
  margin: var(--space-lg) 0;
  padding: var(--space-md) var(--space-lg);
  border-left: 3px solid var(--hairline);
  background: var(--surface-soft);
  color: var(--body);
}
</style>
