---
import Base from '../../../layouts/Base.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import SourceList from '../../../components/SourceList.astro';
import { getAllEvents } from '../../../content';
import { render } from 'astro:content';
import { localizedTitle, localizedSummary } from '../../../lib/i18n';

export async function getStaticPaths() {
  const events = await getAllEvents();
  return events.map((event) => ({ params: { id: event.id }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const title = localizedTitle(event, 'zh');
const summary = localizedSummary(event, 'zh');
const d = event.data.date;
const dateStr = `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
---
<Base title={`${title.text} · 公平档案`} lang="zh" description={summary.text}>
  <article style="max-width:820px;margin:0 auto;padding:48px 32px 96px;">
    <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:16px;">
      <time datetime={d.toISOString()} class="muted">{dateStr}</time>
      <span class="cat">{event.data.category}</span>
      <StatusBadge status={event.data.status} lang="zh" />
    </div>
    <h1>{title.text}</h1>
    <p style="font-size:18px;color:var(--body-strong);line-height:1.6;">{summary.text}</p>
    {event.data.note_zh && <blockquote class="entry-note"><p>{event.data.note_zh}</p></blockquote>}
    <Content />
    <SourceList sources={event.data.sources} lang="zh" />
    {event.data.response && (
      <section class="block">
        <h2>当事方回应</h2>
        <p>{event.data.response.text_zh ?? event.data.response.text_en}</p>
        <SourceList sources={[event.data.response.source]} lang="zh" />
      </section>
    )}
    {event.data.ruling ? (
      <section class="block">
        <h2>后续裁定</h2>
        <p>{event.data.ruling.verdict_zh ?? event.data.ruling.verdict_en}</p>
        <SourceList sources={[event.data.ruling.source]} lang="zh" />
      </section>
    ) : (
      <p class="muted">暂无官方裁定记录。</p>
    )}
  </article>
</Base>
<style>
.cat { font-size: 12px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
.muted { color: var(--muted); }
.block { margin-top: var(--space-lg); padding-top: var(--space-lg); border-top: 1px solid var(--hairline); }
.entry-note {
  margin: var(--space-lg) 0;
  padding: var(--space-md) var(--space-lg);
  border-left: 3px solid var(--hairline);
  background: var(--surface-soft);
  color: var(--body);
}
</style>
